---
interface Props {
  size?: number;
}
const { size = 32 } = Astro.props;
---

<svg
  viewBox="0 0 32 32"
  width={size}
  height={size}
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="stream4j"
>
  <g stroke="currentColor" stroke-width="2" stroke-linecap="square">
    <path d="M3 5 L13 16" />
    <path d="M3 10 L13 16" />
    <path d="M3 16 L13 16" />
    <path d="M3 22 L13 16" />
    <path d="M3 27 L13 16" />
    <path d="M13 16 L29 16" stroke-width="2.5" />
  </g>
  <path
    d="M27 13 L30 16 L27 19"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="square"
    stroke-linejoin="miter"
    fill="none"
  />
  <circle cx="13" cy="16" r="2.5" fill="currentColor" />
</svg>
