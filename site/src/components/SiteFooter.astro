---
import Logo from './Logo.astro';

const year = new Date().getFullYear();

const rawBase = import.meta.env.BASE_URL;
const baseUrl = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const docsHref = `${baseUrl}getting-started/`;
const javadocHref = `${baseUrl}javadoc/`;
---

<footer class="s4j-footer">
  <div class="s4j-shell s4j-footer-inner">
    <div>
      <div
        style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px; color: var(--s4j-fg);"
      >
        <span
          style="display: inline-grid; place-items: center; width: 22px; height: 22px; color: var(--s4j-accent);"
        >
          <Logo size={20} />
        </span>
        <span>stream4j · MIT License · © {year} bbobbogi</span>
      </div>
      <div>chzzk4j 기반 · OkHttp · Gson · Selenium</div>
    </div>
    <div style="display: flex; gap: 24px; flex-wrap: wrap;">
      <a href="https://github.com/bbobbogi/stream4j">GitHub</a>
      <a href={docsHref}>Docs</a>
      <a href={javadocHref}>Javadoc</a>
      <a href="https://github.com/bbobbogi/stream4j/blob/main/LICENSE">License</a>
    </div>
  </div>
</footer>
